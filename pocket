#!/usr/bin/env sh
# =============================================================================
# PocketCli — pocket
# Main CLI. Pure POSIX sh. Works on iSH / Alpine / Linux / macOS.
# =============================================================================

set -eu

POCKETCLI_DIR="${HOME}/.pocketcli"
SCRIPTS="${POCKETCLI_DIR}/scripts"

# Load shared helpers
. "${SCRIPTS}/lib/common.sh"

# =============================================================================
# Commands
# =============================================================================

_cmd_help() {
    echo ""
    printf "  ${C_BOLD}PocketCli${C_NC}  ${C_DIM}— portable terminal toolkit${C_NC}\n"
    echo ""
    printf "  ${C_BOLD}Usage:${C_NC}  pocket [-e|--explain] <command> [args]\n"
    echo ""
    printf "  ${C_CYAN}connect${C_NC}  [host]           SSH into a machine\n"
    printf "  ${C_CYAN}list${C_NC}                     List Tailscale machines\n"
    printf "  ${C_CYAN}run${C_NC}      <host> <cmd>    Run command remotely\n"
    printf "  ${C_CYAN}copy${C_NC}     <src>  <dst>    scp wrapper (host:path)\n"
    printf "  ${C_CYAN}fleet${C_NC}    <sub>  [args]   Commands across machines\n"
    printf "  ${C_CYAN}status${C_NC}                   Local node status\n"
    printf "  ${C_CYAN}radar${C_NC}                    Radar dashboard\n"
    printf "  ${C_CYAN}menu${C_NC}                     Interactive menu\n"
    printf "  ${C_CYAN}resume${C_NC}                   Restore/attach the PocketCli tmux session\n"
    echo ""
    printf "  ${C_CYAN}tailscale-setup${C_NC}          Install + start + auth (shows QR)\n"
    printf "  ${C_CYAN}tailscale-start${C_NC}          Start tailscaled daemon\n"
    printf "  ${C_CYAN}tailscale-restart${C_NC}        Restart tailscaled daemon\n"
    printf "  ${C_CYAN}tailscale-status${C_NC}         Show Tailscale peers and IP\n"
    printf "  ${C_CYAN}tailscale-auth${C_NC}           Re-authenticate (shows QR)\n"
    echo ""
    printf "  ${C_CYAN}doctor${C_NC}                   Run compatibility tests\n"
    printf "  ${C_CYAN}update${C_NC}                   Update PocketCli\n"
    printf "  ${C_CYAN}uninstall${C_NC}                Remove PocketCli\n"
    printf "  ${C_CYAN}help${C_NC}                     This help\n"
    printf "  ${C_CYAN}-e, --explain${C_NC}            Show explicit logs for each execution step\n"
    echo ""
    if is_ish; then
        printf "  ${C_DIM}[iSH detected — using compatible mode]${C_NC}\n\n"
    fi
}

_cmd_list() {
    require tailscale; require jq
    TS_STATUS=$(with_timeout 10 tailscale status --json 2>/dev/null) \
        || die "Cannot reach Tailscale daemon. Run: pocket tailscale-start"

    echo ""
    printf "  ${C_BOLD}%-22s %-16s %-8s %-12s${C_NC}\n" "Hostname" "IP" "Online" "OS"
    printf "  %-22s %-16s %-8s %-12s\n" \
        "----------------------" "----------------" "--------" "------------"

    printf '%s' "${TS_STATUS}" | jq -r '
        .Peer | to_entries[] | .value |
        "\(.HostName) \(.TailscaleIPs[0] // "n/a") \(if .Online then "yes" else "no" end) \(.OS // "?")"
    ' | while IFS=' ' read -r host ip online os; do
        host=$(safe_host "${host}")
        ip=$(printf '%s' "${ip}" | tr -cd '0-9.:')
        printf "  %-22s %-16s %-8s %-12s\n" "${host}" "${ip}" "${online}" "${os}"
    done
    echo ""
}

_cmd_connect() {
    require tailscale
    HOST="${1:-}"

    if [ -z "${HOST}" ]; then
        # Get online peers
        PEERS=$(with_timeout 10 tailscale status --json 2>/dev/null \
            | jq -r '.Peer | to_entries[] | .value | select(.Online) | .HostName' \
            | sort 2>/dev/null || true)
        [ -z "${PEERS}" ] && die "No online Tailscale machines found."

        echo ""
        echo "  Online machines:"
        echo ""
        I=1
        printf '%s\n' "${PEERS}" | while IFS= read -r h; do
            printf "    %d)  %s\n" "${I}" "${h}"
            I=$((I + 1))
        done
        echo ""
        printf "  Number or hostname: "
        read -r INPUT < /dev/tty

        case "${INPUT}" in
            ''|*[!0-9]*)
                HOST=$(safe_host "${INPUT}")
            ;;
            *)
                HOST=$(printf '%s\n' "${PEERS}" | sed -n "${INPUT}p" | tr -cd 'a-zA-Z0-9._-')
            ;;
        esac
    fi

    HOST=$(safe_host "${HOST}")
    [ -z "${HOST}" ] && die "Invalid hostname."
    info "Connecting to ${HOST}..."
    exec ssh "${HOST}"
}

_cmd_run() {
    [ $# -lt 2 ] && die "Usage: pocket run <host> <command>"
    HOST=$(safe_host "$1"); shift
    [ -z "${HOST}" ] && die "Invalid hostname."
    info "Running on ${HOST}: $*"
    ssh -n -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 "${HOST}" -- "$@"
}

_cmd_copy() {
    [ $# -lt 2 ] && die "Usage: pocket copy <src> <dst>"
    require scp
    info "Copying: $1  ->  $2"
    scp -r "$1" "$2"
    ok "Done."
}

_cmd_status() { exec sh "${SCRIPTS}/pocket-status.sh"; }
_cmd_radar()  { exec sh "${POCKETCLI_DIR}/radar.sh"; }
_cmd_menu()   { exec sh "${SCRIPTS}/pocketcli_menu.sh"; }
_cmd_doctor() { exec sh "${POCKETCLI_DIR}/tests/test_ish.sh"; }

_persist_command_if_needed() {
    case "${1:-}" in
        ''|help|-h|--help|version|-v|--version|resume|__restore) return 0 ;;
    esac
    pocket_save_command "$@"
}

_cmd_resume() {
    require tmux
    SESSION=$(pocket_tmux_session)

    if tmux has-session -t "${SESSION}" 2>/dev/null; then
        info "Reattaching tmux session ${SESSION}..."
    else
        info "Creating tmux session ${SESSION} from the last PocketCli command..."
        if [ ! -s "$(pocket_last_command_file)" ]; then
            pocket_save_command menu
        fi
        tmux new-session -d -s "${SESSION}"
        tmux send-keys -t "${SESSION}" "POCKETCLI_RESTORE=1 '${POCKETCLI_DIR}/pocket' __restore" C-m
        tmux source-file "${HOME}/.config/tmux/tmux.conf" 2>/dev/null || true
    fi

    exec tmux attach-session -t "${SESSION}"
}

_cmd_restore() {
    set --
    FILE=$(pocket_last_command_file)
    if [ -f "${FILE}" ] && [ -s "${FILE}" ]; then
        while IFS= read -r _arg || [ -n "${_arg}" ]; do
            set -- "$@" "${_arg}"
        done < "${FILE}"
    fi

    [ $# -gt 0 ] || set -- menu
    exec sh "${POCKETCLI_DIR}/pocket" "$@"
}

_cmd_fleet() {
    exec sh "${SCRIPTS}/fleet.sh" "$@"
}

_cmd_ts() {
    # All tailscale-* commands delegate to tailscale_daemon.sh
    exec sh "${SCRIPTS}/tailscale_daemon.sh" "$@"
}

_restore_update_stash() {
    REPO_DIR="$1"
    STASH_REF="$2"

    [ -n "${STASH_REF}" ] || return 0

    if git -C "${REPO_DIR}" stash pop --quiet >/dev/null 2>&1; then
        ok "Local changes restored after update."
    else
        warn "Update completed, but local changes need manual review (git -C ${REPO_DIR} stash list)."
    fi
}

_cmd_update() {
    step "Updating PocketCli"
    REPO_DIR="${POCKETCLI_DIR}"
    STASH_REF=""

    explain_step "Preparing repository context"
    explain_kv "repo_dir" "${REPO_DIR}"

    explain_step "Checking stash state before update"
    BEFORE_STASH=$(git -C "${REPO_DIR}" rev-parse -q --verify refs/stash 2>/dev/null || true)
    explain_kv "stash_before" "${BEFORE_STASH:-none}"

    explain_step "Checking local modifications"
    WORKTREE_STATUS=$(git -C "${REPO_DIR}" status --porcelain 2>/dev/null || true)
    if [ -n "${WORKTREE_STATUS}" ]; then
        explain "Local modifications detected; creating a temporary stash before updating."
        explain_block "worktree_status" "${WORKTREE_STATUS}"
        info "Saving local changes before update..."
        git -C "${REPO_DIR}" stash push --include-untracked --quiet -m "pocketcli-update" >/dev/null 2>&1 || true
        AFTER_STASH=$(git -C "${REPO_DIR}" rev-parse -q --verify refs/stash 2>/dev/null || true)
        explain_kv "stash_after_push" "${AFTER_STASH:-none}"
        if [ -n "${AFTER_STASH}" ] && [ "${AFTER_STASH}" != "${BEFORE_STASH}" ]; then
            STASH_REF="${AFTER_STASH}"
            explain_kv "active_temp_stash" "${STASH_REF}"
        else
            explain "No new stash entry was created; continuing without a temporary stash reference."
        fi
    else
        explain "Working tree is clean; update will run without creating a stash."
    fi

    explain_step "Fetching remote changes"
    if git -C "${REPO_DIR}" fetch --quiet origin; then
        explain "Fetch completed successfully."
    else
        warn "Update failed — check git status."
        explain "Fetch failed; restoring any temporary stash before exiting."
        _restore_update_stash "${REPO_DIR}" "${STASH_REF}"
        return 0
    fi

    explain_step "Applying fast-forward update"
    if git -C "${REPO_DIR}" pull --ff-only; then
        ok "PocketCli updated."
        explain "Fast-forward pull completed successfully."
    else
        warn "Update failed — check git status."
        explain "Pull failed; restoring any temporary stash before exiting."
        _restore_update_stash "${REPO_DIR}" "${STASH_REF}"
        return 0
    fi

    explain_step "Restoring local modifications"
    _restore_update_stash "${REPO_DIR}" "${STASH_REF}"
}

_cmd_uninstall() { exec sh "${SCRIPTS}/uninstall.sh"; }

_cmd_version() {
    VER=$(git -C "${POCKETCLI_DIR}" describe --tags --always 2>/dev/null || printf 'dev')
    printf 'PocketCli %s\n' "${VER}"
}

# =============================================================================
# Dispatch
# =============================================================================

_has_interactive_tty() {
    [ -r /dev/tty ] || [ -c /dev/tty ]
}

POCKETCLI_EXPLAIN="${POCKETCLI_EXPLAIN:-0}"
while [ $# -gt 0 ]; do
    case "$1" in
        -e|--explain)
            POCKETCLI_EXPLAIN=1
            shift
            ;;
        *)
            break
            ;;
    esac
done
export POCKETCLI_EXPLAIN

CMD="${1:-}"
if [ -z "${CMD}" ]; then
    if _has_interactive_tty; then
        if [ -z "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
            CMD="resume"
        else
            CMD="menu"
        fi
    else
        CMD="help"
    fi
else
    shift
fi

if explain_enabled; then
    explain_step "PocketCli invocation"
    explain_kv "command" "${CMD}"
    explain_kv "args" "$*"
    explain_kv "home" "${HOME}"
    explain_kv "pocketcli_dir" "${POCKETCLI_DIR}"
fi

_persist_command_if_needed "${CMD}" "$@"

case "${CMD}" in
    connect)                    _cmd_connect "$@" ;;
    list|ls)                    _cmd_list ;;
    run)                        _cmd_run "$@" ;;
    copy|cp)                    _cmd_copy "$@" ;;
    fleet)                      _cmd_fleet "$@" ;;
    scan)                       exec sh "${POCKETCLI_DIR}/discovery/pocketcli-scan.sh" ;;
    status)                     _cmd_status ;;
    radar)                      _cmd_radar ;;
    menu)                       _cmd_menu ;;
    doctor)                     _cmd_doctor ;;
    resume)                     _cmd_resume ;;
    __restore)                  _cmd_restore ;;
    tailscale-setup)            _cmd_ts setup ;;
    tailscale-start)            _cmd_ts start ;;
    tailscale-restart)          _cmd_ts restart ;;
    tailscale-stop)             _cmd_ts stop ;;
    tailscale-status)           _cmd_ts status ;;
    tailscale-auth)             _cmd_ts auth ;;
    update)                     _cmd_update ;;
    uninstall)                  _cmd_uninstall ;;
    version|-v|--version)       _cmd_version ;;
    help|-h|--help|"")          _cmd_help ;;
    *)
        warn "Unknown command: '${CMD}'"
        _cmd_help; exit 1
    ;;
esac
